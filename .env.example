# ═══════════════════════════════════════════════════════════════════════
# BOOST BOSS — Environment Variables
# Copy to .env.local for local dev, or set in Vercel → Settings → Env Vars
# ═══════════════════════════════════════════════════════════════════════

# ── Supabase (required for production) ────────────────────────────────
# Get from: supabase.com → Project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Auth ──────────────────────────────────────────────────────────────
# Random 32+ char string. openssl rand -hex 32
JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# ── Stripe (required for billing) ────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Get from: dashboard.stripe.com → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── RTB / BBX ─────────────────────────────────────────────────────────
# Set to "true" to require Bearer auth on all /api/rtb POST requests.
# Unauthenticated bids are rejected with 401. Always "true" in production.
BBX_SEAT_AUTH_REQUIRED=true

# Exchange take rate (default 0.15 = 15%). Publisher gets 1 - this.
BBX_TAKE_RATE=0.15

# Minimum payout threshold in USD (default $100).
BBX_MIN_PAYOUT=100

# Public base URL for callback URLs, nurl macros, etc.
BOOSTBOSS_BASE_URL=https://boostboss.ai

# ── Vercel ────────────────────────────────────────────────────────────
# Set automatically by Vercel, but declare for local dev:
NODE_ENV=production
