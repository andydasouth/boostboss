{
  "version": 2,
  "name": "boostboss",
  "routes": [
    { "src": "/advertiser", "dest": "/public/advertiser.html" },
    { "src": "/developer", "dest": "/public/developer.html" },
    { "src": "/demo", "dest": "/public/demo.html" },
    { "src": "/sdk.js", "dest": "/public/sdk.js", "headers": { "Content-Type": "application/javascript", "Cache-Control": "public, max-age=3600" } },
    { "src": "/api/mcp", "dest": "/api/mcp.js" },
    { "src": "/api/track", "dest": "/api/track.js" },
    { "src": "/api/stats", "dest": "/api/stats.js" },
    { "src": "/api/campaigns", "dest": "/api/campaigns.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
